#!/usr/bin/env python3
"""cellsignal feeder for the Intel XMM7360 (iosm kernel driver).

Publishes Cell Signal contract-v2 JSON (see docs/CONTRACT.md) to /run/cellsignal.json.
Per tick it issues four safe AT reads on the command port: AT+XMCI=1 (serving
trio + EARFCN + Timing-Advance + type-5 neighbours), AT+GTCAINFO? (carrier
aggregation: component-carrier count, per-carrier band/bandwidth), AT+CSCON?
(RRC idle/connected) and AT+COPS? (operator name, served from a short-lived
cache to skip most round-trips). AT+XCESQ? is a fallback for the measurement
trio only. Never publishes device/subscriber identifiers — measurements only,
by contract (TAC/cell-id/PCI in the XMCI/GTCAINFO responses are parsed past,
never returned).

The AT port is a wwan char device, not a tty: plain fd + select with generous
read windows, replies terminated by OK/ERROR. /dev/wwan0at1 answers commands;
/dev/wwan0at0 only broadcasts URCs. Port access is serialized with other AT
tooling on the host via /run/lte-at.lock.

usage: cellsignal-feeder-xmm7360 [--print|--write|--debug]
"""
import contextlib
import fcntl
import json
import os
import select
import signal
import subprocess
import sys
import tempfile
import time

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from xmm7360_decode import (  # noqa: E402
    band_for_earfcn,
    distance_m,
    freq_mhz_for_earfcn,
    parse_cops_operator,
    parse_cscon,
    parse_gtcainfo,
    parse_xcesq,
    parse_xmci,
    quality_pct,
)

OUT = '/run/cellsignal.json'
AT_PORT = '/dev/wwan0at1'       # command port; at0 is URC-broadcast only
AT_LOCK = '/run/lte-at.lock'    # shared with other AT tooling (e.g. lte status)
IFACE = 'wwan0'
OP_CACHE = '/run/cellsignal-operator'   # operator name; publishable, not an identifier
OP_TTL = 300                    # operator changes rarely: re-query AT+COPS? at most every 5 min


class Timeout(Exception):
    pass


def with_timeout(secs, fn, *args, **kw):
    # `armed` closes the SIGALRM cancellation race: if the alarm fires after
    # fn returns but before alarm(0) runs, the handler must not raise and
    # discard a successful result.
    armed = [False]

    def _alarm(signum, frame):
        if armed[0]:
            raise Timeout()

    signal.signal(signal.SIGALRM, _alarm)
    armed[0] = True
    signal.alarm(secs)
    try:
        return fn(*args, **kw)
    finally:
        armed[0] = False
        signal.alarm(0)


def build_contract(decoded, state, now):
    d = decoded or {}
    connected = state == 'connected'
    carriers = d.get('carriers')
    aggregation = None
    if carriers is not None:
        aggregation = {
            'carriers': carriers,
            'bands': d.get('bands') or [],
            'aggregate_mhz': d.get('aggregate_mhz'),
        }
    return {
        'version': 2,
        'ts': now,
        'state': state,
        'tech': 'lte' if connected else None,
        'metrics': {
            'rsrp_dbm': d.get('rsrp_dbm'),
            'rsrq_db': d.get('rsrq_db'),
            'snr_db': d.get('snr_db'),
            'rssi_dbm': None,
        },
        'cell': {
            'band': d.get('band'),
            'earfcn': d.get('earfcn'),
            'freq_mhz': d.get('freq_mhz'),
            'bandwidth_mhz': d.get('bandwidth_mhz'),
            'timing_advance': d.get('timing_advance'),
            'distance_m': d.get('distance_m'),
            'rrc_state': d.get('rrc_state'),
        },
        'aggregation': aggregation,
        'neighbors': d.get('neighbors') or [],
        'operator': d.get('operator'),
        'quality_pct': d.get('quality_pct'),
        'source': 'xmm7360',
    }


def read_operator_cache():
    """Return the cached operator name if fresh, else None. The operator
    changes rarely, so a cache spares an AT+COPS? round-trip most ticks."""
    try:
        if time.time() - os.stat(OP_CACHE).st_mtime > OP_TTL:
            return None
        with open(OP_CACHE) as f:
            return f.read().strip() or None
    except OSError:
        return None


def write_operator_cache(name):
    """Persist the operator name atomically. Best-effort: cache-write failures
    never abort a publish."""
    if not name:
        return
    try:
        fd, tmp = tempfile.mkstemp(dir=os.path.dirname(OP_CACHE), prefix='.cellsignal-op.')
        with os.fdopen(fd, 'w') as f:
            f.write(name + '\n')
            os.fchmod(f.fileno(), 0o644)
        os.replace(tmp, OP_CACHE)
    except OSError:
        with contextlib.suppress(OSError, NameError):
            os.unlink(tmp)


def iface_up():
    # Either address family counts: some carriers assign IPv6-only bearers.
    # scope global excludes the link-local fe80:: that every up interface has.
    r = subprocess.run(['ip', '-o', 'addr', 'show', 'dev', IFACE, 'scope', 'global'],
                       capture_output=True, text=True)
    return 'inet' in r.stdout


def at_read(fd, secs, stop_on_term=True):
    buf, end = b'', time.time() + secs
    while time.time() < end:
        readable, _, _ = select.select([fd], [], [], 0.15)
        if not readable:
            continue
        try:
            chunk = os.read(fd, 4096)
        except BlockingIOError:
            continue                # no data ready yet
        # Hard OSError (EIO/ENODEV on reset/unplug) and EOF both mean the device
        # died mid-session: raise so read_state keeps the last published value —
        # silently returning an empty buffer would publish a bogus error doc
        # (and an EOF-hot select loop would spin at 100% CPU until the deadline).
        if not chunk:
            raise OSError('AT port EOF (device reset?)')
        buf += chunk
        if stop_on_term and (b'OK' in buf or b'ERROR' in buf):
            break
    return buf.decode('latin-1')


def at_chat(fd, cmd, secs=3.0, debug=False):
    os.write(fd, cmd.encode('ascii') + b'\r')
    resp = at_read(fd, secs)
    if debug:
        print(f'{cmd} -> {resp!r}', file=sys.stderr)
    return resp


def query_modem(debug=False):
    """One AT session producing the full v2 decode: serving measurements +
    band/frequency/quality, Timing-Advance distance, carrier aggregation, RRC
    state, neighbours and operator. Any field may be None per the parsers.
    All four reads (XMCI/GTCAINFO/CSCON/COPS) were validated non-wedging in the
    #15 drills. Operator is served from a short-lived cache to skip most COPS
    round-trips."""
    operator = read_operator_cache()
    cached = operator is not None
    fd = with_timeout(5, os.open, AT_PORT, os.O_RDWR | os.O_NONBLOCK)
    try:
        at_read(fd, 0.4, stop_on_term=False)        # drain stale URC noise
        at_chat(fd, 'ATE0', secs=1.5, debug=debug)  # echo off; reply ignored
        # XMCI is the live source: its measurement trio moves per sample,
        # while AT+XCESQ?'s report can stay frozen for hours (45-sample
        # side-by-side, 2026-07-18). XCESQ remains only as a fallback when
        # a response omits the trio.
        xmci = parse_xmci(at_chat(fd, 'AT+XMCI=1', secs=4.0, debug=debug))
        if xmci['rsrp_dbm'] is None:
            # Fill ONLY the missing fields from the (stale-prone) XCESQ report —
            # a partial XMCI sample keeps whatever live values it did carry.
            fallback = parse_xcesq(at_chat(fd, 'AT+XCESQ?', debug=debug))
            for k, v in fallback.items():
                if xmci.get(k) is None and v is not None:
                    xmci[k] = v
        gtca = parse_gtcainfo(at_chat(fd, 'AT+GTCAINFO?', secs=3.0, debug=debug))
        rrc = parse_cscon(at_chat(fd, 'AT+CSCON?', secs=2.0, debug=debug))
        if operator is None:
            operator = parse_cops_operator(at_chat(fd, 'AT+COPS?', secs=3.0, debug=debug))
    finally:
        with contextlib.suppress(OSError):
            os.close(fd)
    # Only rewrite the cache on a fresh COPS query, so the file's mtime tracks
    # the last real query and the OP_TTL age check can actually expire.
    if not cached:
        write_operator_cache(operator)
    out = dict(xmci)
    earfcn = out['earfcn']
    out['band'] = band_for_earfcn(earfcn) if earfcn else None
    out['freq_mhz'] = freq_mhz_for_earfcn(earfcn) if earfcn else None
    out['quality_pct'] = quality_pct(out['rsrp_dbm']) if out['rsrp_dbm'] is not None else None
    out['distance_m'] = distance_m(out.get('timing_advance'))
    out['carriers'] = gtca['carriers']
    out['bands'] = gtca['bands']
    out['aggregate_mhz'] = gtca['aggregate_mhz']
    out['bandwidth_mhz'] = gtca['serving_bandwidth_mhz']
    out['rrc_state'] = rrc
    out['operator'] = operator
    return out


def read_state(debug=False):
    """Return (contract_doc | None, keep_last: bool).
    ts is stamped at publication time, after the AT session completes."""
    if not os.path.exists(AT_PORT):
        return build_contract(None, 'no-modem', int(time.time())), False
    if not iface_up():
        return build_contract(None, 'disconnected', int(time.time())), False

    lock = open(AT_LOCK, 'a')   # append: never truncate a lock file another process holds
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        return None, True       # another AT client holds the port; keep last value
    try:
        try:
            decoded = query_modem(debug)
        except (Timeout, OSError) as e:
            print(f'cellsignal-feeder: AT session failed ({type(e).__name__}: {e}); '
                  f'keeping last value', file=sys.stderr)
            return None, True
    finally:
        lock.close()

    if decoded['rsrp_dbm'] is None:
        # Port answered but no measurement — modem attached-but-idle or mid-
        # transition; report error rather than fabricate.
        return build_contract(None, 'error', int(time.time())), False
    return build_contract(decoded, 'connected', int(time.time())), False


def main():
    mode = sys.argv[1] if len(sys.argv) > 1 else '--print'
    if mode not in ('--print', '--write', '--debug'):
        sys.exit(f'usage: cellsignal-feeder-xmm7360 [--print|--write|--debug]  (--write -> {OUT})')
    if os.geteuid() != 0:
        sys.exit('cellsignal-feeder-xmm7360: needs root for the modem AT port')
    signal.signal(signal.SIGTERM, lambda *_: sys.exit(143))

    doc, keep_last = read_state(debug=(mode == '--debug'))
    if keep_last:
        if mode != '--write':
            print('(modem busy — kept last value)')
        return
    text = json.dumps(doc)
    if mode == '--write':
        # Unique temp name: a fixed one lets two concurrent instances
        # truncate/rename each other's file mid-write.
        fd, tmp = tempfile.mkstemp(dir=os.path.dirname(OUT), prefix='cellsignal.')
        try:
            with os.fdopen(fd, 'w') as f:
                f.write(text + '\n')
                os.fchmod(f.fileno(), 0o644)
            os.replace(tmp, OUT)
        except OSError:
            with contextlib.suppress(OSError):
                os.unlink(tmp)
            raise
    else:
        print(text)


if __name__ == '__main__':
    main()
